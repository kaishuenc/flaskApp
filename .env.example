# DATABASE_URL: PostgreSQL connection string.
# On Render, this is auto-injected when you link the Postgres service.
# For local dev, paste Render's "External Database URL" or run a local Postgres.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NODE_ENV: "production" enables SSL on the DB connection (required by Render).
NODE_ENV="production"
